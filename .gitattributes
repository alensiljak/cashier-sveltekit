# Default: normalize to LF on commit, checkout as-is on Linux
* text=auto eol=lf

# Explicitly LF for source files
*.ts    text eol=lf
*.svelte text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.wasm  binary
*.pdf   binary
#*.svg   binary
*.ico   binary